# Production — copy to .env.local and fill in your Firebase project values.
# Expo reads EXPO_PUBLIC_* variables at build time.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Stripe (publishable key only — secret key is a Firebase secret, never in .env)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# Emulator flag (omit or set to false in production)
EXPO_PUBLIC_USE_EMULATOR=false

# Emulator host — 127.0.0.1 for simulator, LAN IP for physical device
EXPO_PUBLIC_EMULATOR_HOST=127.0.0.1
