{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_USE_EMULATOR": "false",
        "GOOGLE_SERVICES_PLIST": "$GOOGLE_SERVICES_PLIST"
      }
    },
    "development:simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_USE_EMULATOR": "true",
        "EXPO_PUBLIC_EMULATOR_HOST": "127.0.0.1"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_USE_EMULATOR": "false",
        "GOOGLE_SERVICES_PLIST": "$GOOGLE_SERVICES_PLIST"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_USE_EMULATOR": "false",
        "GOOGLE_SERVICES_PLIST": "$GOOGLE_SERVICES_PLIST"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
